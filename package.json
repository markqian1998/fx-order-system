{
  "name": "poseidon-trade-ops",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "node -r dotenv/config server.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -mw",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "asar": false,
    "asarUnpack": [
    "**/node_modules/@sinclair/typebox/**",
    "**/node_modules/tough-cookie/**",
    "**/node_modules/tough-cookie-file-store/**"
    ],
    "appId": "com.yourcompany.poseidon",
    "productName": "Poseidon Trade Ops",
    "mac": {
      "target": "dmg",
      "icon": "assets/mac-icon.png",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/win-icon.ico"
    },
    "extraResources": [
      "assets/**",
      "renderer/**",
      "counterparty.json"
    ]
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "yahoo-finance2": "^2.13.3"
  },
  "devDependencies": {
    "electron": "^36.2.0",
    "electron-builder": "^24.13.3"
  }
}
