# Copy this file to .env (in this directory for dev,
# or in app userData dir for installed app — see README) and fill in real values.

# Airtable Personal Access Token with read scope on the Poseidon DB base.
AIRTABLE_PAT=

# Poseidon DB base ID. Override only if pointing at a different base.
AIRTABLE_BASE_ID=app2U49wa2ylprOBP

# Accounts table ID (within the base above).
AIRTABLE_ACCOUNTS_TABLE_ID=tblVOMFxcFEBZSRMU
